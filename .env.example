# Firebase Configuration
# Get these values from Firebase Console > Project Settings > Your apps > Web app
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Google Maps API Key
# Get this from Google Cloud Console > APIs & Services > Credentials
# IMPORTANT: Restrict this key to your domain and specific APIs (Maps JavaScript API, Places API)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Development Settings
# Set to "true" to use Firebase local emulators (requires emulators to be running)
# Set to "false" to use live Firebase project
VITE_USE_EMULATORS=false
